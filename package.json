{
  "name": "ai-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest --watch",
    "test:integration": "./scripts/run-integration-tests.sh",
    "test:integration:manual": "VITEST_INTEGRATION=1 vitest run",
    "test:integration:ui": "VITEST_INTEGRATION=1 vitest --ui",
    "test:integration:watch": "VITEST_INTEGRATION=1 vitest --watch",
    "test": "./scripts/run-all-tests.sh",
    "test:ci": "vitest run && VITEST_INTEGRATION=1 vitest run && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed": "tsx prisma/seed.ts",
    "prepare": "husky"
  },
