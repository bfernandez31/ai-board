// ============================================================================
// ENUM: JobStatus
// ============================================================================
// Purpose: Valid job execution states
// Values: PENDING (not started), RUNNING (executing), COMPLETED (success), FAILED (error/timeout)
//
enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ============================================================================
// MODEL: Job
// ============================================================================
// Purpose: Track spec-kit workflow command executions with status and logs
// Relationships: Many-to-one with Ticket (cascade delete)
// Indexes: ticketId, status, startedAt, composite(ticketId+status+startedAt)
//
model Job {
  // Primary Key
  id          Int       @id @default(autoincrement())

  // Foreign Key (required, cascade delete when ticket deleted)
  ticketId    Int

  // Command Information
  command     String    @db.VarChar(50)        // spec-kit command: specify, plan, task, implement, clarify

  // Status Tracking
  status      JobStatus @default(PENDING)      // Current execution state

  // Git Metadata (optional - may be unavailable at job creation)
  branch      String?   @db.VarChar(200)       // Git branch (nullable)
  commitSha   String?   @db.VarChar(40)        // Git commit SHA-1 hash (nullable)

  // Execution Logs (optional - populated during/after execution)
  logs        String?   @db.Text               // Full execution logs including errors (unlimited length)

  // Timestamps
  startedAt   DateTime  @default(now())        // When job execution began
  completedAt DateTime?                        // When job finished (nullable - null while running)
  createdAt   DateTime  @default(now())        // Record creation time
  updatedAt   DateTime  @updatedAt             // Last update time

  // Relations
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Indexes for query performance
  @@index([ticketId])                          // Query jobs by ticket
  @@index([status])                            // Query jobs by status
  @@index([startedAt])                         // Query jobs by time range
  @@index([ticketId, status, startedAt])       // Composite for common query pattern
}

