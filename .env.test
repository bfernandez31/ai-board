# Test Environment Configuration for CI/CD
# This file is used by GitHub Actions workflows
# DO NOT use this file for local development - use .env or .env.test.local instead

# Database (PostgreSQL service container in workflows)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_board_test

# NextAuth Configuration (Test Mode)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-key-for-ci-cd-only-do-not-use-in-production

# GitHub OAuth (Test Mode - Mock credentials, not used in actual auth)
GITHUB_ID=mock-github-client-id-for-tests
GITHUB_SECRET=mock-github-client-secret-for-tests

# GitHub Integration - Will be replaced by GitHub Secret in workflows
# This is a placeholder value for the template
GITHUB_TOKEN=${GITHUB_TOKEN}

# Workflow API Authentication
# Uses consistent test token that matches test code defaults
# In production CI/CD, override with WORKFLOW_API_TOKEN secret
WORKFLOW_API_TOKEN=test-workflow-token-for-e2e-tests-only

# Application URL
APP_URL=http://localhost:3000

# Cloudinary Configuration (Test Mode - Will be replaced by GitHub Secrets)
CLOUDINARY_CLOUD_NAME=${CLOUDINARY_CLOUD_NAME}
CLOUDINARY_API_KEY=${CLOUDINARY_API_KEY}
CLOUDINARY_API_SECRET=${CLOUDINARY_API_SECRET}

# Test Mode Flag
TEST_MODE=true

# Node Environment
NODE_ENV=test
