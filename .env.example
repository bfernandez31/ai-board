# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai-board"

# GitHub repository configuration for default project
GITHUB_OWNER="your-github-username"
GITHUB_REPO="ai-board"

# AI Integration (future)
ANTHROPIC_API_KEY="sk-ant-..."

# GitHub Integration - Classic token with repo + workflow scopes
# Required for: Automated workflow dispatch when tickets transition between stages
# Scopes needed: repo (full repository access), workflow (trigger GitHub Actions)
GITHUB_TOKEN="ghp_YOUR_TOKEN_HERE"

# Optional
NODE_ENV="development"
PORT="3000"