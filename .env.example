# Database
# Connection pooling optimized for Vercel serverless
# connection_limit: Max connections per instance (10-15 recommended)
# pool_timeout: Connection pool timeout in seconds (20 recommended)
DATABASE_URL="postgresql://user:password@localhost:5432/ai-board?connection_limit=10&pool_timeout=20"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret-here"

# GitHub OAuth (Development)
GITHUB_ID="Ov23liABC..."
GITHUB_SECRET="your-github-oauth-secret"

# GitHub repository configuration for default project
GITHUB_OWNER="your-github-username"
GITHUB_REPO="ai-board"

# AI Integration (future)
ANTHROPIC_API_KEY="sk-ant-..."

# GitHub Integration - Classic token with repo + workflow scopes
# Required for: Automated workflow dispatch when tickets transition between stages
# Scopes needed: repo (full repository access), workflow (trigger GitHub Actions)
GITHUB_TOKEN="ghp_YOUR_TOKEN_HERE"

# Workflow API Authentication
# Used by GitHub Actions workflows to authenticate API calls
# Generate a secure random token: openssl rand -hex 32
# Store in GitHub Secrets as WORKFLOW_API_TOKEN
# Store in Vercel environment variables
WORKFLOW_API_TOKEN="your-secure-random-token-here"

# Application URL (for GitHub Actions workflows)
# Development: http://localhost:3000
# Production: Set as GitHub Repository Variable (APP_URL)
# This is used by workflows to call back to the API
APP_URL="http://localhost:3000"

# Dev Login (Preview Environments Only)
# Set to a 32+ char secret to enable dev login on preview environments
DEV_LOGIN_SECRET=
# Set to 'true' to show dev login form on signin page
NEXT_PUBLIC_DEV_LOGIN=

# Optional
NODE_ENV="development"
PORT="3000"
# Cloudinary Configuration (Image Storage)
# Sign up at https://cloudinary.com (free tier: 25GB storage, 25GB bandwidth/month)
# Required for: Image attachments in tickets
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Push Notifications (VAPID Keys)
# Generate keys with: npx web-push generate-vapid-keys
# Required for: Browser push notifications for job completion and @mentions
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:notifications@ai-board.dev"
