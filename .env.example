# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai-board"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret-here"

# GitHub OAuth (Development)
GITHUB_ID="Ov23liABC..."
GITHUB_SECRET="your-github-oauth-secret"

# GitHub repository configuration for default project
GITHUB_OWNER="your-github-username"
GITHUB_REPO="ai-board"

# AI Integration (future)
ANTHROPIC_API_KEY="sk-ant-..."

# GitHub Integration - Classic token with repo scope
# Required for: Git operations (clone, commit, push) by the worker
# Scopes needed: repo (full repository access)
GITHUB_TOKEN="ghp_YOUR_TOKEN_HERE"

# Redis Configuration (for worker queue)
# Local: redis://localhost:6379
# Production: Use Upstash or Redis Cloud URL
REDIS_URL="redis://localhost:6379"

# Workflow API Authentication
# Used by Worker service to authenticate API callbacks
# Generate a secure random token: openssl rand -hex 32
# Store in worker environment variables
WORKFLOW_API_TOKEN="your-secure-random-token-here"

# Application URL (for Worker API callbacks)
# Development: http://localhost:3000 or http://host.docker.internal:3000 (from Docker)
# Production: Your deployed application URL
# This is used by the worker to call back to the API
APP_URL="http://localhost:3000"

# Optional
NODE_ENV="development"
PORT="3000"
# Cloudinary Configuration (Image Storage)
# Sign up at https://cloudinary.com (free tier: 25GB storage, 25GB bandwidth/month)
# Required for: Image attachments in tickets
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
